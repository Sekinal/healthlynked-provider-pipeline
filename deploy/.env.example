# Copy to .env at the repo root and fill in. NEVER commit the real .env.

# OpenRouter (LLM reconciliation + model bake-off). Required for --reconcile / bakeoff.
OPENROUTER_API_KEY=

# Database. Local dev defaults to SQLite; compose injects Postgres.
DATABASE_URL=sqlite:///./healthlynked.db
# DATABASE_URL=postgresql+psycopg://hl:hl@localhost:5432/healthlynked

REDIS_URL=redis://localhost:6379/0

# Optional: comma-separated proxy URLs for the web-enrichment tier (tiered rotation).
# HL_PROXIES=http://user:pass@dc-proxy:8000,http://user:pass@res-proxy:8000

# Optional: set to 1 to enable the CloakBrowser stealth-browser tier (downloads binary).
# HL_ENABLE_CLOAKBROWSER=1

# MinIO (raw source-snapshot storage in compose).
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=minio12345
